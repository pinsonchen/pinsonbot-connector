{
  "name": "pinsonbot",
  "version": "2.17.0",
  "description": "OpenClaw Channel Plugin for PinsonBots Platform with media support, security hardening, auto-update, and heartbeat mechanism",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "check-update": "node dist/src/updater.js --check",
    "auto-update": "node dist/src/updater.js --update"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "channel",
    "pinsonbot",
    "websocket"
  ],
  "author": "pinsonchen",
  "license": "MIT",
  "dependencies": {
    "openclaw": "file:/usr/lib/node_modules/openclaw",
    "@mariozechner/pi-agent-core": "0.61.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.18.1",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.13"
  },
  "openclaw": {
    "id": "pinsonbot",
    "extensions": [
      "./index.ts"
    ]
  }
}
