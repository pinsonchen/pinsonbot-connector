{
  "id": "pinsonbot",
  "channels": ["pinsonbot"],
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "endpoint": {
        "type": "string",
        "default": "wss://tools.pinsonbot.com/pinsonbots/internal/plugin"
      },
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "lobsterId": { "type": "string" },
            "internalToken": { "type": "string" },
            "name": { "type": "string" }
          },
          "required": ["lobsterId", "internalToken"]
        }
      }
    }
  }
}