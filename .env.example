# PinsonBot Connector Configuration Example
# Copy this file to .env and fill in your actual values

# ===========================================
# PinsonBots Platform Configuration
# ===========================================
# Enable/disable PinsonBot channel (true/false)
PINSONBOT_ENABLED=true

# WebSocket endpoint for Plugin connection
# This is the internal plugin endpoint on PinsonBots Platform
PINSONBOT_ENDPOINT=ws://localhost:8000/pinsonbots/internal/plugin

# ===========================================
# Account Configuration (Per-Lobster Credentials)
# ===========================================
# Format: PINSONBOT_ACCOUNT_<NAME>=<lobsterId>:<internalToken>
# Each lobster has its own unique internal_token
#
# IMPORTANT:
# - lobsterId: 10-character string (e.g., "aB3xK9mN2p")
# - internalToken: 128-character hex string, unique per lobster
# - These credentials are ONLY returned at lobster creation time
# - Save them immediately and keep them secure!
#
# Example:
# PINSONBOT_ACCOUNT_CUSTOMER_SERVICE=aB3xK9mN2p:abc123def456...
# PINSONBOT_ACCOUNT_SALES=xY7pL2qR5n:xyz789uvw456...

# ===========================================
# Connection Retry Configuration (Optional)
# ===========================================
# Maximum reconnection attempts (default: 5)
# PINSONBOT_MAX_RECONNECT_ATTEMPTS=5

# Initial delay between retries in ms (default: 5000)
# PINSONBOT_RECONNECT_DELAY_MS=5000

# Exponential backoff multiplier (default: 2)
# PINSONBOT_BACKOFF_MULTIPLIER=2

# ===========================================
# Logging Configuration
# ===========================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Optional: Log file path (if not specified, logs to console only)
# LOG_FILE_PATH=/var/log/pinsonbot-connector.log
